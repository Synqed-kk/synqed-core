# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# API Keys (comma-separated, one per client app)
API_KEYS=karute-dev-key-change-me,synq-dev-key-change-me

# Server
PORT=3100

# Supabase Storage (required for staff avatar upload endpoint)
# Used by POST /v1/staff/:id/avatar to store files in the "avatars" bucket
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]
