generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Customer — core business-scoped entity
// =============================================================================

model Customer {
  id              String   @id @default(uuid()) @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  name            String
  furigana        String?
  email           String?
  phone           String?
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  gender          String?
  occupation            String?  @map("occupation")
  memberNumber          String?  @map("member_number")
  postalCode            String?  @map("postal_code")
  prefecture            String?
  address               String?
  phone2                String?
  dmOptIn               Boolean  @default(false) @map("dm_opt_in")
  comment               String?
  remarks2              String?
  totalSales            Int      @default(0) @map("total_sales")
  installmentOutstanding Int     @default(0) @map("installment_outstanding")
  hasTicketPack         Boolean  @default(false) @map("has_ticket_pack")
  firstVisitAt          DateTime? @map("first_visit_at") @db.Timestamptz()
  lastVisitAt           DateTime? @map("last_visit_at") @db.Timestamptz()
  locale          String   @default("ja")
  notes           String?
  contactInfo     String?  @map("contact_info")
  assignedStaffId String?  @map("assigned_staff_id") @db.Uuid
  // Returning-customer signal + lifetime visit count. Populated by external
  // syncs (e.g. QuickReserve's is_existing_customer / visits_number_cache);
  // default to first-time / 0 for customers created in-app.
  isExistingCustomer Boolean @default(false) @map("is_existing_customer")
  visitCount         Int     @default(0) @map("visit_count")
  // Per-business sequential chart number (カルテNo). Assigned at create
  // (max+1 within the business); the manual migration backfills existing
  // rows by created_at. Display formatting (#00001) is the app's job.
  karuteNumber       Int?    @map("karute_number")
  // External system references (e.g. { quickreserve: { customerId: 12345 } })
  externalRefs    Json     @default("{}") @map("external_refs")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  appointments Appointment[]
  photos       CustomerPhoto[]
  consents     RecordingConsent[]
  visits       CustomerVisit[]

  @@unique([businessId, email])
  @@unique([businessId, karuteNumber])
  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, email])
  @@map("customers")
}

// =============================================================================
// CustomerVisit — one row per QuickReserve reservation, crawled into synqed-core
// to surface a customer's visit / treatment / sales history.
// =============================================================================

model CustomerVisit {
  id               String   @id @default(uuid()) @db.Uuid
  businessId       String   @map("business_id") @db.Uuid
  storeId          String?  @map("store_id") @db.Uuid
  customerId       String   @map("customer_id") @db.Uuid
  qrReservationId  Int      @map("qr_reservation_id")
  usedAt           DateTime @map("used_at") @db.Timestamptz()
  status           String   // 'settled' | 'booked' | 'cancelled'
  courseName       String?  @map("course_name")
  salesAmount      Int      @default(0) @map("sales_amount")
  staffName        String?  @map("staff_name")
  treatmentComment String?  @map("treatment_comment")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([businessId, qrReservationId])
  @@index([customerId, usedAt])
  @@index([businessId, storeId])
  @@map("customer_visits")
}

// =============================================================================
// RecordingConsent — per-customer recording consent for APPI / privacy compliance.
// One active row per customer (revoked rows preserved for audit).
// =============================================================================

enum ConsentMethod {
  VERBAL
  WRITTEN
}

model RecordingConsent {
  id                 String        @id @default(uuid()) @db.Uuid
  businessId         String        @map("business_id") @db.Uuid
  customerId         String        @map("customer_id") @db.Uuid
  grantedByStaffId   String        @map("granted_by_staff_id") @db.Uuid
  grantedAt          DateTime      @default(now()) @map("granted_at") @db.Timestamptz()
  method             ConsentMethod @default(VERBAL)
  policyVersion      String        @map("policy_version")
  revokedAt          DateTime?     @map("revoked_at") @db.Timestamptz()
  revokedByStaffId   String?       @map("revoked_by_staff_id") @db.Uuid

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([customerId, revokedAt])
  @@map("recording_consents")
}

// =============================================================================
// CustomerPhoto — per-customer photo metadata; bytes live in Supabase Storage
// =============================================================================

model CustomerPhoto {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  storagePath String   @map("storage_path")
  category    String   @default("general")
  caption     String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([customerId, createdAt])
  @@map("customer_photos")
}

// =============================================================================
// Staff — business members who take bookings / do karute
// =============================================================================

enum StaffRole {
  OWNER
  ADMIN
  STYLIST
  ASSISTANT
}

model Staff {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String    @map("business_id") @db.Uuid
  userId     String?   @unique @map("user_id") @db.Uuid
  name       String
  nameKana   String?   @map("name_kana")
  email      String?
  role       StaffRole @default(STYLIST)
  isActive   Boolean   @default(true) @map("is_active")
  pinHash    String?   @map("pin_hash")
  avatarUrl  String?   @map("avatar_url")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, name])
  @@map("staff")
}

// =============================================================================
// Appointment — booking from any source (manual or skimmed from Quick Reserve etc.)
// =============================================================================

enum AppointmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AppointmentSource {
  MANUAL
  QUICKRESERVE
  SYNQED_RESERVE
  SALON_BOARD
  HOT_PEPPER
  OTHER
}

model Appointment {
  id              String            @id @default(uuid()) @db.Uuid
  businessId      String            @map("business_id") @db.Uuid
  storeId         String?           @map("store_id") @db.Uuid
  customerId      String            @map("customer_id") @db.Uuid
  staffId         String            @map("staff_id") @db.Uuid
  startsAt        DateTime          @map("starts_at") @db.Timestamptz()
  endsAt          DateTime          @map("ends_at") @db.Timestamptz()
  durationMinutes Int?              @map("duration_minutes")
  title           String?
  notes           String?
  status          AppointmentStatus @default(SCHEDULED)
  source          AppointmentSource @default(MANUAL)
  // External system references. Shape: { quickreserve: { reservationId: 12345, rid: "abc" } }
  externalRefs    Json              @default("{}") @map("external_refs")
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz()
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  customer Customer @relation(fields: [customerId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])

  @@index([businessId, startsAt])
  @@index([customerId, startsAt])
  @@index([staffId, startsAt])
  // External-ref-based dedup for upserts
  @@index([businessId, source])
  @@index([businessId, storeId])
  @@map("appointments")
}

// =============================================================================
// SyncConfig — per-business external booking system integration config
// =============================================================================

enum SyncProvider {
  QUICKRESERVE
  SYNQED_RESERVE
  SALON_BOARD
  HOT_PEPPER
}

enum SyncStatus {
  OK
  ERROR
  RUNNING
}

model SyncConfig {
  id                   String       @id @default(uuid()) @db.Uuid
  businessId           String       @map("business_id") @db.Uuid
  provider             SyncProvider
  // Encrypted credentials (AES-256-GCM). Shape of decrypted payload depends on provider.
  // For QUICKRESERVE: { username, password, storeSlug, storeId }
  credentialsEncrypted Bytes?       @map("credentials_encrypted")
  // Non-secret config that the UI displays / edits
  username             String?
  storeSlug            String?      @map("store_slug")
  storeId              Int?         @map("store_id")
  // Karute LOCATION (uuid) this QR config feeds — synced events get stamped with it.
  // Distinct from storeId above (the QR API's numeric store id).
  karuteStoreId        String?      @map("karute_store_id") @db.Uuid
  // Scheduling
  enabled              Boolean      @default(false)
  intervalMinutes      Int          @default(15) @map("interval_minutes")
  businessHoursStart   Int          @default(8) @map("business_hours_start") // hour 0-23
  businessHoursEnd     Int          @default(22) @map("business_hours_end") // hour 0-23
  timezone             String       @default("Asia/Tokyo")
  // Date window: how many days forward to sync (today = 0, tomorrow = 1, ...)
  lookaheadDays        Int          @default(7) @map("lookahead_days")
  // Status
  lastRunAt            DateTime?    @map("last_run_at") @db.Timestamptz()
  lastRunStatus        SyncStatus?  @map("last_run_status")
  lastRunError         String?      @map("last_run_error")
  lastRunStats         Json         @default("{}") @map("last_run_stats") // { created, updated, cancelled, skipped, unmatchedStaff[] }
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([businessId, provider])
  @@index([enabled, lastRunAt])
  @@map("sync_configs")
}

// =============================================================================
// RecordingSession — audio capture + transcription lifecycle
// =============================================================================

enum RecordingStatus {
  RECORDING
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
}

model RecordingSession {
  id               String          @id @default(uuid()) @db.Uuid
  businessId       String          @map("business_id") @db.Uuid
  storeId          String?         @map("store_id") @db.Uuid
  customerId       String?         @map("customer_id") @db.Uuid
  staffId          String          @map("staff_id") @db.Uuid
  appointmentId    String?         @map("appointment_id") @db.Uuid
  audioStoragePath String?         @map("audio_storage_path")
  durationSeconds  Int?            @map("duration_seconds")
  status           RecordingStatus @default(RECORDING)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  segments     TranscriptionSegment[]
  karuteRecord KaruteRecord?

  @@index([businessId, createdAt])
  @@index([customerId])
  @@index([staffId])
  @@index([businessId, storeId])
  @@map("recording_sessions")
}

// =============================================================================
// TranscriptionSegment — ordered chunks of transcript for a recording
// =============================================================================

model TranscriptionSegment {
  id                 String   @id @default(uuid()) @db.Uuid
  recordingSessionId String   @map("recording_session_id") @db.Uuid
  segmentIndex       Int      @map("segment_index")
  text               String
  startTime          Float    @map("start_time")
  endTime            Float    @map("end_time")
  speakerLabel       String?  @map("speaker_label")
  confidence         Float?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  recordingSession RecordingSession @relation(fields: [recordingSessionId], references: [id], onDelete: Cascade)

  @@index([recordingSessionId, segmentIndex])
  @@map("transcription_segments")
}

// =============================================================================
// KaruteRecord — per-session clinical/service notes (header)
// =============================================================================

enum KaruteStatus {
  DRAFT
  REVIEW
  APPROVED
}

model KaruteRecord {
  id                 String       @id @default(uuid()) @db.Uuid
  businessId         String       @map("business_id") @db.Uuid
  storeId            String?      @map("store_id") @db.Uuid
  customerId         String?      @map("customer_id") @db.Uuid
  staffId            String       @map("staff_id") @db.Uuid
  lastEditedByStaffId String?     @map("last_edited_by_staff_id") @db.Uuid
  appointmentId      String?      @map("appointment_id") @db.Uuid
  recordingSessionId String?      @unique @map("recording_session_id") @db.Uuid
  status             KaruteStatus @default(DRAFT)
  aiSummary          String?      @map("ai_summary")
  transcript         String?
  // Session metadata captured by the manual-create dialog (and later the
  // recording flow): what was performed, how long, and the actual session
  // day (backdating support — createdAt is the row insert time).
  service            String?
  durationMinutes    Int?         @map("duration_minutes")
  sessionDate        DateTime?    @map("session_date") @db.Date
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  entries          KaruteEntry[]
  recordingSession RecordingSession? @relation(fields: [recordingSessionId], references: [id])

  @@index([businessId, createdAt])
  @@index([customerId])
  @@index([staffId])
  @@index([businessId, storeId])
  @@map("karute_records")
}

// =============================================================================
// KaruteEntry — categorized items inside a karute record
// =============================================================================

enum EntryCategory {
  SYMPTOM
  TREATMENT
  BODY_AREA
  PREFERENCE
  LIFESTYLE
  NEXT_VISIT
  PRODUCT
  OTHER
}

model KaruteEntry {
  id             String        @id @default(uuid()) @db.Uuid
  karuteRecordId String        @map("karute_record_id") @db.Uuid
  category       EntryCategory
  content        String
  originalQuote  String?       @map("original_quote")
  confidence     Float         @default(0)
  tags           String[]      @default([])
  sortOrder      Int           @default(0) @map("sort_order")
  isManual       Boolean       @default(false) @map("is_manual")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  karuteRecord KaruteRecord @relation(fields: [karuteRecordId], references: [id], onDelete: Cascade)

  @@index([karuteRecordId, sortOrder])
  @@map("karute_entries")
}

// =============================================================================
// OrgSettings — per-business config bag (replaces karute's Organization.settings JSON)
// =============================================================================

model OrgSettings {
  businessId String   @id @map("business_id") @db.Uuid
  name       String?
  settings   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("org_settings")
}

// =============================================================================
// AiRequestLog — append-only log of AI API calls for per-business rate limiting
// =============================================================================

model AiRequestLog {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  route      String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  tokensIn   Int?     @map("tokens_in")
  tokensOut  Int?     @map("tokens_out")
  costCents  Int?     @map("cost_cents")

  @@index([businessId, createdAt])
  @@map("ai_request_log")
}

// =============================================================================
// Store — physical location (multi-store). The store_id on the event tables
// (#16) references these. Consolidated from the karute app DB into core so the
// stores live next to the events that key on them (single source of truth).
// =============================================================================

model Store {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  name       String
  address    String?
  phone      String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([businessId])
  @@map("stores")
}

// =============================================================================
// BusinessEntitlement — plan tier + comp/dev unlimited override (store cap).
// Consolidated from the karute app DB. One row per business; absent = 'free'.
// =============================================================================

model BusinessEntitlement {
  businessId  String   @id @map("business_id") @db.Uuid
  tier        String   @default("free")
  isUnlimited Boolean  @default(false) @map("is_unlimited")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("business_entitlements")
}

// =============================================================================
// StaffStore — many-to-many staff↔store assignment (multi-store). Consolidated
// from the karute app DB's profile_stores; re-keyed on core staff ids (the
// karute profile_id maps to core staff via staff.user_id). Zero rows for a
// staff = "works in every store".
// =============================================================================

model StaffStore {
  staffId    String   @map("staff_id") @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@id([staffId, storeId])
  @@index([businessId, storeId])
  @@map("staff_stores")
}

// =============================================================================
// Invite — staff invitation, consolidated from the karute app DB.
// =============================================================================

model Invite {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String    @map("business_id") @db.Uuid
  email      String
  role       String
  token      String    @unique
  status     String    @default("pending")
  invitedBy  String?   @map("invited_by") @db.Uuid
  // The existing staff row this invite re-activates (accept sets its user_id)
  // instead of minting a duplicate. Null = a brand-new person (email-only invite).
  invitedStaffId String? @map("invited_staff_id") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz()

  @@index([businessId])
  @@map("invites")
}

// =============================================================================
// CustomerMemoryItem — "AI Customer Memory" notes, consolidated from karute.
// =============================================================================

model CustomerMemoryItem {
  id                  String    @id @default(uuid()) @db.Uuid
  businessId          String    @map("business_id") @db.Uuid
  customerId          String    @map("customer_id")
  category            String
  label               String
  detail              String?
  source              String?
  confidence          Float?
  pinned              Boolean   @default(false)
  suggestTalkingPoint Boolean   @default(false) @map("suggest_talking_point")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([businessId, customerId])
  @@map("customer_memory_items")
}

// =============================================================================
// KaruteOutcome — a session's coaching outcome label (success / no_deal /
// pending …), consolidated from the karute app DB. Keyed on the karute record
// (one outcome per record); the app upserts on karute_record_id.
// =============================================================================

model KaruteOutcome {
  karuteRecordId String    @id @map("karute_record_id") @db.Uuid
  businessId     String    @map("business_id") @db.Uuid
  customerId     String?   @map("customer_id") @db.Uuid
  outcome        String
  reason         String?
  isFirstVisit   Boolean   @default(false) @map("is_first_visit")
  decidedBy      String?   @map("decided_by") @db.Uuid
  decidedAt      DateTime? @map("decided_at") @db.Timestamptz()
  autoDecided    Boolean   @default(false) @map("auto_decided")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([businessId])
  @@map("karute_outcomes")
}

// =============================================================================
// 回数券 (ticket-pack) subsystem — consolidated from the karute app DB. All
// customer-keyed; business_id is the tenant scope (derived from the customer at
// migrate time; set from x-business-id on new writes). The app keeps the usage
// aggregation (FIFO, 残 counts) — core just serves business-scoped rows.
// =============================================================================

model TicketPack {
  id            String    @id @default(uuid()) @db.Uuid
  businessId    String    @map("business_id") @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  kind          String
  packSize      Int       @map("pack_size")
  unitPrice     Int       @map("unit_price")
  totalPrice    Int?      @map("total_price")
  purchaseRound Int       @default(0) @map("purchase_round")
  purchasedAt   DateTime? @map("purchased_at") @db.Date
  source        String    @default("manual")
  status        String
  notes         String?
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([businessId, customerId])
  @@index([businessId, status])
  @@map("ticket_packs")
}

model PackRedemption {
  id             String   @id @default(uuid()) @db.Uuid
  businessId     String   @map("business_id") @db.Uuid
  packId         String   @map("pack_id") @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  redeemedOn     DateTime @map("redeemed_on") @db.Date
  appointmentId  String?  @map("appointment_id")
  karuteRecordId String?  @map("karute_record_id")
  source         String   @default("manual")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([businessId, customerId])
  @@index([businessId, packId])
  @@index([businessId, redeemedOn])
  @@map("pack_redemptions")
}

model PackAlertDismissal {
  id          String    @id @default(uuid()) @db.Uuid
  businessId  String    @map("business_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  dismissedBy String    @map("dismissed_by") @db.Uuid
  reason      String?
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([businessId, customerId])
  @@map("pack_alert_dismissals")
}

model CustomerContact {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  channel     String
  alertKind   String?  @map("alert_kind")
  note        String?
  contactedBy String   @map("contacted_by") @db.Uuid
  contactedAt DateTime @default(now()) @map("contacted_at") @db.Timestamptz()

  @@index([businessId, customerId])
  @@index([businessId, contactedAt])
  @@map("customer_contacts")
}

model VisitReconcileDismissal {
  id            String   @id @default(uuid()) @db.Uuid
  businessId    String   @map("business_id") @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  appointmentId String?  @map("appointment_id")
  visitDay      DateTime @map("visit_day") @db.Date
  dismissedBy   String   @map("dismissed_by") @db.Uuid
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([businessId, customerId])
  @@index([businessId, visitDay])
  @@map("visit_reconcile_dismissals")
}

model CustomerLifecycle {
  customerId      String    @id @map("customer_id") @db.Uuid
  businessId      String    @map("business_id") @db.Uuid
  status          String
  referral        Boolean   @default(false)
  statusChangedAt DateTime? @map("status_changed_at") @db.Timestamptz()
  reason          String?
  updatedBy       String?   @map("updated_by") @db.Uuid
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([businessId])
  @@map("customer_lifecycle")
}

// =============================================================================
// AiCache — global AI-response cache (key = hash of the input), consolidated
// from the karute app DB. NOT tenant-scoped (matches the app's existing global
// cache); the routes are API-key-gated but business-optional.
// =============================================================================

model AiCache {
  cacheKey  String   @id @map("cache_key")
  result    Json
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([expiresAt])
  @@map("ai_cache")
}
