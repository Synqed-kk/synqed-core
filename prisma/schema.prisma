generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Customer — core tenant-scoped entity
// =============================================================================

model Customer {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String
  furigana        String?
  email           String?
  phone           String?
  locale          String   @default("ja")
  notes           String?
  contactInfo     String?  @map("contact_info")
  assignedStaffId String?  @map("assigned_staff_id") @db.Uuid
  // External system references (e.g. { quickreserve: { customerId: 12345 } })
  externalRefs    Json     @default("{}") @map("external_refs")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  appointments Appointment[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@map("customers")
}

// =============================================================================
// Staff — tenant members who take bookings / do karute
// =============================================================================

enum StaffRole {
  OWNER
  ADMIN
  STYLIST
  ASSISTANT
}

model Staff {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String?   @unique @map("user_id") @db.Uuid
  name      String
  nameKana  String?   @map("name_kana")
  email     String?
  role      StaffRole @default(STYLIST)
  isActive  Boolean   @default(true) @map("is_active")
  pinHash   String?   @map("pin_hash")
  avatarUrl String?   @map("avatar_url")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  appointments Appointment[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("staff")
}

// =============================================================================
// Appointment — booking from any source (manual or skimmed from Quick Reserve etc.)
// =============================================================================

enum AppointmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AppointmentSource {
  MANUAL
  QUICKRESERVE
  SYNQED_RESERVE
  SALON_BOARD
  HOT_PEPPER
  OTHER
}

model Appointment {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  customerId      String            @map("customer_id") @db.Uuid
  staffId         String            @map("staff_id") @db.Uuid
  startsAt        DateTime          @map("starts_at") @db.Timestamptz()
  endsAt          DateTime          @map("ends_at") @db.Timestamptz()
  durationMinutes Int?              @map("duration_minutes")
  title           String?
  notes           String?
  status          AppointmentStatus @default(SCHEDULED)
  source          AppointmentSource @default(MANUAL)
  // External system references. Shape: { quickreserve: { reservationId: 12345, rid: "abc" } }
  externalRefs    Json              @default("{}") @map("external_refs")
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz()
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  customer Customer @relation(fields: [customerId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])

  @@index([tenantId, startsAt])
  @@index([customerId, startsAt])
  @@index([staffId, startsAt])
  // External-ref-based dedup for upserts
  @@index([tenantId, source])
  @@map("appointments")
}

// =============================================================================
// SyncConfig — per-tenant external booking system integration config
// =============================================================================

enum SyncProvider {
  QUICKRESERVE
  SYNQED_RESERVE
  SALON_BOARD
  HOT_PEPPER
}

enum SyncStatus {
  OK
  ERROR
  RUNNING
}

model SyncConfig {
  id                   String       @id @default(uuid()) @db.Uuid
  tenantId             String       @map("tenant_id") @db.Uuid
  provider             SyncProvider
  // Encrypted credentials (AES-256-GCM). Shape of decrypted payload depends on provider.
  // For QUICKRESERVE: { username, password, storeSlug, storeId }
  credentialsEncrypted Bytes?       @map("credentials_encrypted")
  // Non-secret config that the UI displays / edits
  username             String?
  storeSlug            String?      @map("store_slug")
  storeId              Int?         @map("store_id")
  // Scheduling
  enabled              Boolean      @default(false)
  intervalMinutes      Int          @default(15) @map("interval_minutes")
  businessHoursStart   Int          @default(8) @map("business_hours_start") // hour 0-23
  businessHoursEnd     Int          @default(22) @map("business_hours_end") // hour 0-23
  timezone             String       @default("Asia/Tokyo")
  // Date window: how many days forward to sync (today = 0, tomorrow = 1, ...)
  lookaheadDays        Int          @default(7) @map("lookahead_days")
  // Status
  lastRunAt            DateTime?    @map("last_run_at") @db.Timestamptz()
  lastRunStatus        SyncStatus?  @map("last_run_status")
  lastRunError         String?      @map("last_run_error")
  lastRunStats         Json         @default("{}") @map("last_run_stats") // { created, updated, cancelled, skipped, unmatchedStaff[] }
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([tenantId, provider])
  @@index([enabled, lastRunAt])
  @@map("sync_configs")
}

// =============================================================================
// RecordingSession — audio capture + transcription lifecycle
// =============================================================================

enum RecordingStatus {
  RECORDING
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
}

model RecordingSession {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  customerId       String?         @map("customer_id") @db.Uuid
  staffId          String          @map("staff_id") @db.Uuid
  appointmentId    String?         @map("appointment_id") @db.Uuid
  audioStoragePath String?         @map("audio_storage_path")
  durationSeconds  Int?            @map("duration_seconds")
  status           RecordingStatus @default(RECORDING)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  segments     TranscriptionSegment[]
  karuteRecord KaruteRecord?

  @@index([tenantId, createdAt])
  @@index([customerId])
  @@index([staffId])
  @@map("recording_sessions")
}

// =============================================================================
// TranscriptionSegment — ordered chunks of transcript for a recording
// =============================================================================

model TranscriptionSegment {
  id                 String   @id @default(uuid()) @db.Uuid
  recordingSessionId String   @map("recording_session_id") @db.Uuid
  segmentIndex       Int      @map("segment_index")
  text               String
  startTime          Float    @map("start_time")
  endTime            Float    @map("end_time")
  speakerLabel       String?  @map("speaker_label")
  confidence         Float?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  recordingSession RecordingSession @relation(fields: [recordingSessionId], references: [id], onDelete: Cascade)

  @@index([recordingSessionId, segmentIndex])
  @@map("transcription_segments")
}

// =============================================================================
// KaruteRecord — per-session clinical/service notes (header)
// =============================================================================

enum KaruteStatus {
  DRAFT
  REVIEW
  APPROVED
}

model KaruteRecord {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @map("tenant_id") @db.Uuid
  customerId         String?      @map("customer_id") @db.Uuid
  staffId            String       @map("staff_id") @db.Uuid
  appointmentId      String?      @map("appointment_id") @db.Uuid
  recordingSessionId String?      @unique @map("recording_session_id") @db.Uuid
  status             KaruteStatus @default(DRAFT)
  aiSummary          String?      @map("ai_summary")
  transcript         String?
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  entries          KaruteEntry[]
  recordingSession RecordingSession? @relation(fields: [recordingSessionId], references: [id])

  @@index([tenantId, createdAt])
  @@index([customerId])
  @@index([staffId])
  @@map("karute_records")
}

// =============================================================================
// KaruteEntry — categorized items inside a karute record
// =============================================================================

enum EntryCategory {
  SYMPTOM
  TREATMENT
  BODY_AREA
  PREFERENCE
  LIFESTYLE
  NEXT_VISIT
  PRODUCT
  OTHER
}

model KaruteEntry {
  id             String        @id @default(uuid()) @db.Uuid
  karuteRecordId String        @map("karute_record_id") @db.Uuid
  category       EntryCategory
  content        String
  originalQuote  String?       @map("original_quote")
  confidence     Float         @default(0)
  tags           String[]      @default([])
  sortOrder      Int           @default(0) @map("sort_order")
  isManual       Boolean       @default(false) @map("is_manual")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  karuteRecord KaruteRecord @relation(fields: [karuteRecordId], references: [id], onDelete: Cascade)

  @@index([karuteRecordId, sortOrder])
  @@map("karute_entries")
}

// =============================================================================
// OrgSettings — per-tenant config bag (replaces karute's Organization.settings JSON)
// =============================================================================

model OrgSettings {
  tenantId  String   @id @map("tenant_id") @db.Uuid
  name      String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("org_settings")
}
